# Stagepass monorepo – copy to .env in each app as needed

# ---------------------------------------------------------------------------
# Backend (backend/laravel-api/.env)
# ---------------------------------------------------------------------------
# APP_NAME=Stagepass
# APP_URL=http://localhost:8000
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=stagepass
# DB_USERNAME=root
# DB_PASSWORD=
# FIREBASE_CREDENTIALS=  # path to Firebase service account JSON for FCM

# ---------------------------------------------------------------------------
# Mobile (mobile/stagepass-mobile) – use app.json / EAS or .env
# ---------------------------------------------------------------------------
# EXPO_PUBLIC_API_URL=http://localhost:8000
# For Android emulator use: http://10.0.2.2:8000
# For iOS simulator use: http://localhost:8000
