# API base URL (required in production). No trailing slash.
# Production: https://api.winenot.co.ke
# Local: http://localhost:8000
VITE_API_URL=https://api.winenot.co.ke

# Optional: for location search when creating/editing events (Google Places Autocomplete).
# 1. Create a key at https://console.cloud.google.com/apis/credentials
# 2. Enable "Maps JavaScript API" and "Places API" (APIs & Services > Library)
# 3. Enable billing for the project (required for Places)
# 4. If using key restrictions, add http://localhost:* and your production origin
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
