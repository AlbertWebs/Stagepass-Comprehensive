APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Optional: comma-separated origins for the web admin SPA (when it is on a different host than the API).
# If unset, CORS allows *. Example: https://admin.stagepass.co.ke,http://localhost:5173
# CORS_ALLOWED_ORIGINS=
# Office check-in "today" and checkins list use this (e.g. Africa/Nairobi). Leave unset for UTC.
# APP_TIMEZONE=Africa/Nairobi

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# log = write to laravel.log only (no real delivery). Use smtp (or ses/postmark/resend) in production.
# After changing MAIL_* on the server: php artisan config:clear  (or rebuild config cache with config:cache).
MAIL_MAILER=log
# Optional DSN (overrides host/port/user/pass when set). Example: smtp://user:pass@mail.example.com:587
# MAIL_URL=
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# Legacy: ssl -> smtps (often port 465). For port 587 STARTTLS, leave MAIL_SCHEME null and use port 587.
# MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="Stagepass"
# If the SMTP server rejects EHLO, set explicitly (e.g. mail.example.com). Otherwise: APP_URL host, or MAIL_HOST when it is a hostname (not an IP) — so local APP_URL + real SMTP still EHLOs correctly.
# MAIL_EHLO_DOMAIN=
# Email theme: stagepass (brand colors). All notification emails use this.
MAIL_MARKDOWN_THEME=stagepass
# Web admin URL for "Reset password" link in forgot-password email (e.g. https://admin.stagepass.com/reset-password)
# FRONTEND_PASSWORD_RESET_URL=

# Firebase Cloud Messaging (push): path to service account JSON (e.g. storage/app/firebase-credentials.json)
# FIREBASE_CREDENTIALS=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
