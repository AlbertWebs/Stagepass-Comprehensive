# Local development — copy to `.env` and adjust.
# Store builds: set the same keys in Expo → Environment variables (per profile), or EAS secrets.

# Required for release/store builds (must be HTTPS for `production` profile — matches Android usesCleartextTraffic: false).
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com

# Local / emulator (HTTP OK for dev only)
EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# Optional: API request logging (dev only; do not enable in production)
# EXPO_PUBLIC_API_LOGS=1

# Optional: Google Places (event addresses)
# EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
