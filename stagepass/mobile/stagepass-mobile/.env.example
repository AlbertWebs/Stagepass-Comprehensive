# API base URL for the Stagepass Laravel backend (no trailing slash).
# The API codebase lives at: C:\projects\Stapepass-mobile-app-api
# Web Admin lives at: C:\projects\Stapepass-mobile-app-webadmin
# This mobile app remains in the current repo. Set EXPO_PUBLIC_API_URL to the
# URL where your API is served. Copy this file to .env and restart Expo after changing.
#
# Production:
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com
#
# Local (API running from Stapepass-mobile-app-api):
# EXPO_PUBLIC_API_URL=http://0.0.0.0:8000
# - Android emulator:      http://10.0.2.2:8000
# - Physical device:      http://YOUR_PC_IP:8000
#
EXPO_PUBLIC_API_URL=http://0.0.0.0:8000

# Daily (office) check-in: location is a 30m radius. Get lat/lng from your office on Google Maps
# (e.g. https://maps.app.goo.gl/wZg18AJBwUt9kJdj7 → right-click map → copy coordinates).
# EXPO_PUBLIC_OFFICE_CHECKIN_LAT=-1.292066
# EXPO_PUBLIC_OFFICE_CHECKIN_LNG=36.821946
# EXPO_PUBLIC_OFFICE_CHECKIN_RADIUS_M=100

# Optional: Google Places API key for location search when creating/editing events.
# Enable "Places API (New)" in Google Cloud. Without this, location is plain text only.
# Use any one of these (app.config.js also reads VITE_* from .env):
# EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_key
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_key
# VITE_GOOGLE_MAPS_API_KEY=your_key
