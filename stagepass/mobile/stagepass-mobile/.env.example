# API base URL for the Stagepass Laravel backend.
# Copy this file to .env and set EXPO_PUBLIC_API_URL. Restart Expo after changing.
#
# - iOS simulator / web:   http://localhost:8000
# - Android emulator:     http://10.0.2.2:8000
# - Physical device:      http://YOUR_PC_IP:8000  (e.g. http://192.168.56.1:8000)
#   Find your IP: Windows (ipconfig), Mac/Linux (ifconfig or ip addr)
#
EXPO_PUBLIC_API_URL=http://192.168.56.1:8000
